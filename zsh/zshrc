# --- PATH & env ---
export PATH="$HOME/.local/bin:$PATH"

# --- Locale & colors (fixes "ugly" SSH sessions, broken accented chars, etc.) ---
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR=1
export LSCOLORS=GxFxCxDxBxegedabagaced

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS SHARE_HISTORY INC_APPEND_HISTORY EXTENDED_HISTORY

# --- QoL ---
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS INTERACTIVE_COMMENTS
bindkey -e

# --- Completion ---
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'

# --- Aliases ---
alias ls="ls -lahG"
alias ll="ls -lah"
alias la="ls -A"
alias ..="cd .."
alias ...="cd ../.."
alias gs="git status"
alias gd="git diff"
alias gl="git log --oneline --graph --decorate -20"

# --- nvm ---
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# --- Plugins (must be loaded BEFORE starship init for syntax highlighting to work right) ---
[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Tokyo Night-friendly autosuggest color
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#565f89"

# --- Starship prompt ---
eval "$(starship init zsh)"

# --- iTerm2 shell integration (loaded last; safe no-op outside iTerm2) ---
[ -f "$HOME/.iterm2_shell_integration.zsh" ] && source "$HOME/.iterm2_shell_integration.zsh"

# --- Personal customizations (not tracked by this repo) ---
# ~/.zshrc.local is never touched by bootstrap.sh — put your aliases / exports here.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
